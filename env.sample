# Gemini AI API Keys (Get these from Google AI Studio)
# Use comma-separated list for automatic key rotation and rate limiting
GEMINI_API_KEYS=your_gemini_api_key_1,you_gemini_api_key_2,you_gemini_api_key_3
GEMINI_API_KEY=your_gemini_api_key_here  # Fallback single key

# OpenAI API Keys (Get these from OpenAI platform or OpenRouter)
# Use comma-separated list for automatic key rotation
OPENAI_API_KEYS=your_openai_api_key_1,you_openai_api_key_2
OPENAI_API_KEY=your_openai_api_key_here  # Fallback single key

# OpenRouter API Keys (Get these from OpenRouter.ai)
# Use comma-separated list for automatic key rotation and model variety
OPENROUTER_API_KEYS=your_openrouter_api_key_1,you_openrouter_api_key_2
OPENROUTER_API_KEY=your_openrouter_api_key_here  # Fallback single key

# ChatGPT API Keys (Get these from OpenAI platform, with Assistants API enabled)
CHATGPT_API_KEYS=your_chatgpt_api_key_1,you_chatgpt_api_key_2
CHATGPT_API_KEY=your_chatgpt_api_key_here  # Fallback single key

# Supabase Configuration
# Found in Project Settings -> API in the Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_STORAGE_BUCKET_NAME=your_bucket_name_here

# MongoDB (Atlas or self-hosted). Keep Supabase only for Storage/Auth.
MONGODB_URI=your_mongodb_connection_string_here

# AI Provider Configuration
# Priority order for provider fallback (used by AIInterventionManager)
AI_PROVIDER_PRIORITY=gemini,openai,openrouter,chatgpt

# AI System Configuration
AI_ENABLE_CACHING=true
AI_MAX_RETRIES=3
AI_CACHE_TTL=300000  # 5 minutes in milliseconds

# Token and Cost Configuration (for metrics)
AI_DEFAULT_PROMPT_TOKENS_PER_REQUEST=1000
AI_DEFAULT_COMPLETION_TOKENS_PER_REQUEST=1000
AI_GEMINI_COST_PER_1K_TOKENS_PROMPT=0.0025
AI_GEMINI_COST_PER_1K_TOKENS_COMPLETION=0.0075
AI_OPENAI_COST_PER_1K_TOKENS_PROMPT=0.0025
AI_OPENAI_COST_PER_1K_TOKENS_COMPLETION=0.0075
